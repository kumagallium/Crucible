# Crucible Registry — 環境変数テンプレート
# このファイルを .env にコピーして設定してください
# cp .env.example .env && chmod 600 .env

# ── Crucible 基本設定 ───────────────────────────────────────
# ポートバインド先 IP（VPN 経由なら WireGuard IP を指定）
CRUCIBLE_HOST=127.0.0.1
# CRUCIBLE_HOST=10.0.0.1  # WireGuard VPN の例

# Registry API の公開ポート
CRUCIBLE_API_PORT=8080

# Registry UI の公開ポート
CRUCIBLE_UI_PORT=8081

# UI に表示する MCP サーバーの SSE ベース URL
CRUCIBLE_BASE_URL=http://127.0.0.1
# CRUCIBLE_BASE_URL=http://10.0.0.1  # VPN 経由の例

# CORS 許可オリジン（カンマ区切り、未設定時は localhost のみ）
# CRUCIBLE_CORS_ORIGINS=http://10.0.0.1:8081,http://localhost:8081

# ── Registry API 認証 ──────────────────────────────────────
# Registry API へのアクセスに必要な API キー
# 生成例: openssl rand -hex 32
REGISTRY_API_KEY=your_random_api_key_here

# ── Dify 連携（任意） ──────────────────────────────────────
# Dify への自動登録に必要（未設定の場合は Dify 登録をスキップ）
DIFY_EMAIL=admin@example.com
DIFY_PASSWORD=your_password
# dify_net 経由で Dify の nginx コンテナに直接接続
DIFY_API_BASE=http://nginx/console/api

# ── GitHub 認証 ────────────────────────────────────────────
# TOKEN_ENCRYPTION_KEY: GitHub Token を暗号化して保存するためのマスターキー
# 生成例: python3 -c "import secrets; print(secrets.token_hex(32))"
# 必ず設定すること。未設定の場合は再起動後に既存tokenの復号が不可能になる。
TOKEN_ENCRYPTION_KEY=your_64_char_hex_key_here

# GITHUB_TOKEN: システム全体のフォールバック用 (個別tokenが未設定の場合に使用)
# 通常は各サーバー登録時に個別tokenを入力するため、設定は任意。
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# ── Docker ネットワーク名 ───────────────────────────────────
MCP_NETWORK=mcp-net
DIFY_NETWORK=docker_default
